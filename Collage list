/* HERO */
.hero{background:linear-gradient(140deg,var(--navy) 0%,#1e3a8a 60%,#0d2257 100%);position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.05) 1px,transparent 1px);background-size:24px 24px}
.hi{position:relative;z-index:2;max-width:860px;margin:0 auto;padding:44px 20px 36px;text-align:center}
.htag{display:inline-block;background:rgba(232,160,32,.2);border:1px solid rgba(232,160,32,.4);color:var(--gold);font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:4px 14px;border-radius:20px;margin-bottom:16px}
.hi h1{font-family:'Playfair Display',serif;font-size:clamp(28px,7vw,56px);font-weight:900;color:#fff;line-height:1.1}
.hi h1 em{font-style:normal;background:linear-gradient(90deg,var(--gold),#fde68a);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hsub{color:rgba(255,255,255,.6);font-size:13.5px;margin-top:8px}
.ccts{display:flex;flex-wrap:wrap;justify-content:center;gap:12px;margin-top:26px}
.cct{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:12px;padding:13px 20px;text-align:center;flex:1;min-width:190px;max-width:250px}
.cct .role{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);margin-bottom:3px}
.cct .nm{font-size:15px;font-weight:700;color:#fff}
.cct .ph{font-size:12px;color:rgba(255,255,255,.6);margin-top:2px}
.adr{display:block;margin-top:14px;font-size:11px;color:rgba(255,255,255,.4)}

/* STATS */
.stats{background:var(--white);border-bottom:1px solid var(--border);box-shadow:var(--sh)}
.sr{max-width:860px;margin:0 auto;display:flex;flex-wrap:wrap}
.si{flex:1;min-width:110px;padding:14px 10px;border-right:1px solid var(--border);text-align:center}
.si:last-child{border-right:none}
.sn{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:var(--navy)}
.sn b{color:var(--gold)}
.sl{font-size:10px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--muted);margin-top:2px}

/* MAIN */
.main{max-width:860px;margin:0 auto;padding:22px 14px 60px}

/* TOOLBAR */
.tb{display:flex;flex-wrap:wrap;gap:10px;align-items:center;margin-bottom:14px}
.sw{position:relative;flex:1;min-width:160px}
.sw svg{position:absolute;left:11px;top:50%;transform:translateY(-50%);width:15px;height:15px;stroke:var(--muted);fill:none;stroke-width:2.2}
.sw input{width:100%;background:var(--white);border:2px solid var(--border);border-radius:10px;padding:11px 12px 11px 36px;font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;color:var(--text);outline:none;transition:border-color .2s;box-shadow:var(--sh)}
.sw input:focus{border-color:var(--navy)}
.sw input::placeholder{color:var(--muted)}
.chip{background:var(--navy);color:#fff;border-radius:8px;padding:10px 14px;font-size:13px;font-weight:600;white-space:nowrap}
.chip b{color:var(--gold)}

/* LEGEND */
.leg-row{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;align-items:center}
.lg{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted);font-weight:500}
.ld{width:9px;height:9px;border-radius:3px;flex-shrink:0}

/* BADGES */
.badge{display:inline-block;padding:3px 8px;border-radius:6px;font-size:11.5px;font-weight:600;white-space:nowrap}
.bs{background:var(--s-bg);color:var(--s-fg)}
.bp{background:var(--p-bg);color:var(--p-fg)}
.bh{background:var(--h-bg);color:var(--h-fg)}
.bm{background:var(--m-bg);color:var(--m-fg)}
.bus{display:inline-block;padding:2px 7px;border-radius:5px;font-size:11px;font-weight:500;background:#F1F5F9;color:var(--muted)}
.busf{background:var(--s-bg);color:var(--s-fg)}

/* ── DESKTOP TABLE ── */
.dtbl{background:var(--white);border-radius:14px;border:1px solid var(--border);overflow:hidden;box-shadow:var(--sh2)}
.dtbl table{width:100%;border-collapse:collapse;font-size:13px}
thead tr{background:linear-gradient(90deg,var(--navy),var(--navy2))}
thead th{padding:12px 9px;font-size:10px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:rgba(255,255,255,.7);text-align:left;white-space:nowrap;border-bottom:2px solid var(--gold)}
thead th:first-child{padding-left:14px;width:34px;text-align:center}
tbody tr{border-bottom:1px solid #EEF2F8;transition:background .1s}
tbody tr:last-child{border-bottom:none}
tbody tr:nth-child(even){background:#F8FAFF}
tbody tr:hover{background:#EFF4FF}
tbody tr.h{display:none}
tbody td{padding:10px 9px;vertical-align:middle}
tbody td:first-child{padding-left:14px;text-align:center;font-size:11px;font-weight:700;color:var(--muted)}
.cn{font-weight:600;color:var(--navy);font-size:13px}
.rf{font-weight:700;font-size:12px;text-align:center}

/* ── MOBILE CARDS ── */
.mcards{display:none}
.mc{background:var(--white);border-radius:14px;border:1px solid var(--border);margin-bottom:11px;overflow:hidden;box-shadow:var(--sh)}
.mc.h{display:none}
.mch{background:linear-gradient(90deg,var(--navy),var(--navy2));padding:12px 16px;display:flex;align-items:center;gap:10px}
.mcn{background:rgba(232,160,32,.25);color:var(--gold);border-radius:6px;padding:2px 8px;font-size:11px;font-weight:800;border:1px solid rgba(232,160,32,.3);flex-shrink:0}
.mct{font-weight:700;color:#fff;font-size:14px;line-height:1.3}
.mcb{padding:10px 16px}
.mr{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid #F1F5F9}
.mr:last-child{border-bottom:none}
.ml{font-size:10.5px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--muted);flex-shrink:0;width:70px}
.mv{text-align:right}

.nr{display:none;text-align:center;padding:36px;color:var(--muted)}
.nr span{font-size:30px;display:block;margin-bottom:8px}

/* FOOTER */
footer{background:var(--navy);text-align:center;padding:28px 20px;color:rgba(255,255,255,.55);font-size:13px;line-height:1.9}
footer strong{color:var(--gold)}

@media print{.call-btn,.tb{display:none!important}.mcards{display:none!important}.dtbl{display:block!important;box-shadow:none!important}body{background:#fff!important}}

/* MOBILE: show cards, hide table */
@media(max-width:660px){
