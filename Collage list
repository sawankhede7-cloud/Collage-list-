function bdg(v){
  const l=v.toLowerCase();
  if(l.includes('full scholar'))return`<span class="badge bs">${v}</span>`;
  if(l.includes('scholar+diff')||l.includes('k+scholar'))return`<span class="badge bm">${v}</span>`;
  const n=parseInt(v.replace(/[^\d]/g,'')||'0');
  if(n>=100000)return`<span class="badge bh">${v}</span>`;
  if(n>0)return`<span class="badge bp">${v}</span>`;
  return`<span class="badge bp">${v}</span>`;
}
function bpill(v){
  const l=v.toLowerCase();
  if(l==='free')return`<span class="bus busf">Free 🚌</span>`;
  if(l==='n/a')return`<span style="color:#CBD5E0">—</span>`;
  return`<span class="bus">${v}</span>`;
}

const dtb=document.getElementById('dtb');
const mcd=document.getElementById('mcd');
let scCount=0;

D.forEach((d,i)=>{
  const lo=d.n.toLowerCase();
  if(d.o.toLowerCase().includes('full scholar'))scCount++;

  // Desktop row
  const tr=document.createElement('tr');
  tr.dataset.n=lo;
  tr.innerHTML=`
    <td>${i+1}</td>
    <td class="cn">${d.n}</td>
    <td class="rf">₹${d.r}</td>
    <td>${bdg(d.o)}</td>
    <td>${bdg(d.s)}</td>
    <td>${bdg(d.g)}</td>
    <td>${bpill(d.b)}</td>`;
  dtb.appendChild(tr);

  // Mobile card
  const mc=document.createElement('div');
  mc.className='mc';mc.dataset.n=lo;
  mc.innerHTML=`
    <div class="mch">
      <span class="mcn">${i+1}</span>
      <span class="mct">${d.n}</span>
    </div>
    <div class="mcb">
      <div class="mr"><span class="ml">Reg. Fee</span><span class="mv"><strong>₹${d.r}</strong></span></div>
      <div class="mr"><span class="ml">OBC</span><span class="mv">${bdg(d.o)}</span></div>
      <div class="mr"><span class="ml">SC / ST</span><span class="mv">${bdg(d.s)}</span></div>
      <div class="mr"><span class="ml">General</span><span class="mv">${bdg(d.g)}</span></div>
      <div class="mr"><span class="ml">Bus</span><span class="mv">${bpill(d.b)}</span></div>
    </div>`;
  mcd.appendChild(mc);
});

document.getElementById('sc').innerHTML=scCount+'<b>+</b>';

function filt(){
  const q=document.getElementById('q').value.trim().toLowerCase();
  let dv=0,mv=0;
  dtb.querySelectorAll('tr').forEach(r=>{
    const m=r.dataset.n.includes(q);
    r.classList.toggle('h',!m);
    if(m)dv++;
  });
  mcd.querySelectorAll('.mc').forEach(c=>{
    const m=c.dataset.n.includes(q);
    c.classList.toggle('h',!m);
    if(m)mv++;
  });
  document.getElementById('vc').textContent=dv;
  document.getElementById('dnr').style.display=dv?'none':'block';
  document.getElementById('mnr').style.display=mv?'none':'block';
}
